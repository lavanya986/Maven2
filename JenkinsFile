pipeline {
    agent any

    tools {
        // These names MUST match what you defined in 
        // Manage Jenkins -> Tools
        jdk 'JDK17'
        maven 'Maven3'
    }

    stages {
        stage('Checkout') {
            steps {
                // This pulls the code from the Git repo defined in the job
                checkout scm
            }
        }

        stage('Build & Test') {
            steps {
                // 'bat' is required for Windows. 
                // 'sh' only works on Linux/Mac.
                bat 'mvn clean test'
            }
        }
    }

    post {
        always {
            // This captures the JUnit XML reports even if tests fail
            junit '**/target/surefire-reports/*.xml'
        }
    }
}
